# ============================================================
# Jessica Career OS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- Job Discovery (optional — enables "Find Today's Jobs" button) ---
# Get a free key at: https://rapidapi.com → search for "JSearch"
RAPIDAPI_KEY=

# --- AI Provider (choose ONE — the app checks in this order) ---

# Option 1: OpenRouter (recommended — works with many models including Claude)
# Get your key at: https://openrouter.ai
OPENROUTER_API_KEY=

# Option 2: Anthropic Claude API directly
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Option 3: OpenAI (GPT-4o)
# Get your key at: https://platform.openai.com
OPENAI_API_KEY=

# --- Database ---
# SQLite file path. Defaults to ./career.db in project root.
DATABASE_URL=./career.db

# --- Notes ---
# You do NOT need an AI key for the app to work.
# AI generation is optional — the template generator always works without a key.
# The app never submits applications automatically, regardless of AI settings.
